# 群晖/NAS 推荐：复制为 runtime.env，改这里即可，无需在 Container Manager 里改环境变量
#   cp runtime.env.example runtime.env
#   vi /volume1/docker/wallpaper-webui/runtime.env
#   docker restart wallpaper-webui
#
# 文件位于挂载目录 /app/app/runtime.env（即宿主机 /volume1/docker/wallpaper-webui/runtime.env）

# ===== HLS 转码策略 =====
# 无 GPU: libx264 | 有 GPU: auto | 仅 NVIDIA: nvenc | 仅 Intel: qsv
HLS_TRANSCODE_FALLBACK=auto

# ===== 路径（与 docker 卷一致，一般不用改）=====
WE_PATH=/data/wallpaper_engine
WORKSHOP_PATH=/data/workshop/content/431960

# ===== 双 GPU =====
# 以下 NVIDIA_* 必须写在 docker run / 群晖「环境变量」里（创建容器时生效）；
# 只写 runtime.env 无法挂载 NVENC 所需的 /dev/nvidia-uvm 等设备。
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,video,utility
#
# Intel QSV/VAAPI：镜像内已设 LD_LIBRARY_PATH、LIBVA_DRIVERS_PATH（Jellyfin deb 自带 libva/iHD），
# 一般无需在此重复。老核显可改 LIBVA_DRIVER_NAME=i965。
LIBVA_DRIVER_NAME=iHD
HLS_QSV_DEVICE=/dev/dri/renderD128

# ===== GPU 转码（双卡）=====
# HLS_PREFER_GPU=1     有 GPU 时不落 libx264，排队等硬编槽位
# HLS_DUAL_GPU=auto    同时有 NVENC+QSV 时按视频分流到独显/集显
# HLS_NVENC_MAX=2      独显并发路数（4060 Ti 建议 2）
# HLS_INTEL_MAX=2      集显并发路数
# HLS_NVENC_MAX=8      4060 Ti 消费级 NVENC 驱动上限 8 路
# HLS_INTEL_MAX=12     12 代 QSV 1080p 实测约 10~14 路
# HLS_NVENC_MAX_PREVIEW=8   preview 540p，NVENC 仍受会话数限制
# HLS_INTEL_MAX_PREVIEW=14  preview 540p，Intel 可略高于 full
# HLS_HW_SLOTS_DYNAMIC=1    遇 encoder busy 等瞬时错误自动降并发
# HLS_HW_ENCODE_SLOT_WAIT_SEC=300  等 GPU 槽位最长时间（秒）

# ===== HLS =====
HLS_ALLOW_COPY=1
HLS_NVENC_CUDA=1
HLS_PREFER_GPU=1
HLS_DUAL_GPU=auto
HLS_NVENC_MAX=8
HLS_INTEL_MAX=12
HLS_NVENC_MAX_PREVIEW=8
HLS_INTEL_MAX_PREVIEW=14
HLS_HW_SLOTS_DYNAMIC=1
HLS_HW_ENCODE_SLOT_WAIT_SEC=300
# preview 首段就绪后是否继续整片编码（0=关，关窗/空闲即停）
HLS_PREVIEW_KEEP_ENCODING=0
HLS_PREVIEW_IDLE_KILL_SEC=20
# 0=浮动窗走 preview HLS 转码（推荐）；1=H.264 直出 MP4（大文件直连 NAS 慢）
HLS_PREVIEW_DIRECT_PLAY=0
HLS_HW_PROBE_RESET=0
HLS_SEGMENT_SEC=2
HLS_CACHE_MAX_TOTAL_GB=20
HLS_CACHE_MAX_AGE_DAYS=30
HLS_START_WAIT_SEC=90
HLS_PLAYLIST_PRIME_SEGMENTS=3
HLS_PLAYLIST_PRIME_WAIT_SEC=6
HLS_DISCONTINUITY_AFTER_GAP_SEGMENTS=2
HLS_COPY_MAX_SOURCE_BYTES=2147483648
HLS_COPY_MAX_BITRATE_BPS=30000000
HLS_HUGE_FILE_BYTES=8589934592
HLS_MAX_REASONABLE_SEGMENT_BYTES=134217728
HLS_ENCODE_AHEAD_SEC=60

# Alt+浮动预览：低码率 HLS（独立缓存 hls_cache_preview/，多窗并发更快）
HLS_PREVIEW_MAX_WIDTH=960
HLS_PREVIEW_MAX_HEIGHT=540
HLS_PREVIEW_AUDIO_BITRATE=96k
HLS_PREVIEW_PLAYLIST_PRIME_SEGMENTS=1
HLS_PREVIEW_PLAYLIST_PRIME_WAIT_SEC=4

# ===== 音频缓存 =====
AUDIO_CACHE_MAX_AGE_DAYS=14
AUDIO_CACHE_MAX_TOTAL_MB=4096
AUDIO_CACHE_CLEAN_INTERVAL_MIN=60

# ===== 播放进度 =====
PROGRESS_COMPLETE_RATIO=0.90
PROGRESS_START_RATIO=0.05
PROGRESS_MIN_POSITION_SEC=5

# ===== 扫描 =====
SCAN_DEBOUNCE_SEC=5
SCAN_FINGERPRINT_INTERVAL=10
SCAN_PENDING_RECHECK_SEC=30

# ===== 其它 =====
DIRECT_PLAY_CHUNK_BYTES=131072
PREWARM_MAX_BYTES=2147483648
SILENCE_KEEPALIVE_LOGS=1
UNSUB_TTL=3600

# ===== Steam 上传者（也可用 steam_config.json）=====
# STEAM_API_KEY=
STEAM_API_BATCH_SIZE=50
STEAM_API_BATCH_DELAY=0.4
STEAM_API_TIMEOUT=30
STEAM_API_RETRIES=5
STEAM_API_CONTINUE_DELAY=30
